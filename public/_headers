# Cloudflare Pages headers for landscapearchive.org

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), autoplay=(), camera=(), clipboard-read=(), clipboard-write=(), display-capture=(), fullscreen=(), geolocation=(), gyroscope=(), hid=(), microphone=(), payment=(), publickey-credentials-get=(), screen-wake-lock=(), serial=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data: https:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; script-src-attr 'none'; connect-src 'self' https://landscapearchive.com.au https://landscapearchive.org; form-action 'self' https://landscapearchive.com.au; upgrade-insecure-requests

/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

/sign-in
  X-Robots-Tag: noindex, nofollow

/sign-in.html
  X-Robots-Tag: noindex, nofollow

/events
  X-Robots-Tag: noindex, nofollow

/events.html
  X-Robots-Tag: noindex, nofollow

# Private Vault redirect gate — never index; no referrer leak to Vault host.
/vault
  X-Robots-Tag: noindex, nofollow, noarchive
  Referrer-Policy: no-referrer
  Cache-Control: private, no-store

/vault/*
  X-Robots-Tag: noindex, nofollow, noarchive
  Referrer-Policy: no-referrer
  Cache-Control: private, no-store

# Hashed Astro assets are immutable
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Public marketing feeds (apex mirror + Ad Studio)
/field-notes.json
  Cache-Control: public, max-age=300, stale-while-revalidate=3600

/recent-updates.json
  Cache-Control: public, max-age=300, stale-while-revalidate=3600

# Registry data can be cached briefly
/foundation-wing/*
  Cache-Control: public, max-age=3600

/scripts/*
  Cache-Control: public, max-age=3600

/foundation-wing/tla185-open-pack.zip
  Content-Type: application/zip
  Cache-Control: public, max-age=3600

/og-foundation.png
  Cache-Control: public, max-age=86400
