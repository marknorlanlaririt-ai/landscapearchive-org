---
import BaseLayout from '../../layouts/BaseLayout.astro'
import SectionShareLinks from '../../components/SectionShareLinks.astro'
import { GOVERNANCE_PATH, TLA185_DISPLAY_ID } from '../../data/foundationWing.js'
import {
  getOrbitBySlug,
  STANDARDS_ORBIT_MATURITY_BANNER,
  STANDARDS_ORBITS,
  STANDARDS_ORBITS_INDEX_PATH
} from '../../data/standardsOrbits.js'
import { readFileSync } from 'node:fs'
import { fileURLToPath } from 'node:url'

export function getStaticPaths() {
  return STANDARDS_ORBITS.map((orbit) => ({
    params: { orbit: orbit.slug }
  }))
}

const slug = Astro.params.orbit
const orbit = getOrbitBySlug(slug)

if (!orbit) {
  throw new Error(`Unknown orbit slug: ${slug}`)
}

const examplePath = fileURLToPath(
  new URL(`../../../public${orbit.exampleHref}`, import.meta.url)
)
const exampleJson = readFileSync(examplePath, 'utf8').trim()
---

<BaseLayout title={orbit.title} description={orbit.description} path={orbit.path}>
  <article class="page orbit">
    <header class="orbit__head prose">
      <p class="eyebrow">
        <a class="orbit__back" href={STANDARDS_ORBITS_INDEX_PATH}>Standards</a>
        {' · '}
        <a class="orbit__back" href={`${GOVERNANCE_PATH}#standards-constellation`}>Constellation</a>
      </p>
      <p class="orbit__maturity" role="status">{orbit.maturityLabel}</p>
      <h1>{orbit.title}</h1>
      <p class="orbit__dek">{orbit.description}</p>
      <p class="orbit__banner" role="note">{STANDARDS_ORBIT_MATURITY_BANNER}</p>
      <p class="orbit__schema">
        Schema id: <code>{orbit.schemaId}</code>
        {' · '}
        Spine: <a href="/registry">{TLA185_DISPLAY_ID}</a>
      </p>
      <SectionShareLinks title={orbit.title} pagePath={orbit.path} anchorId={orbit.slug} />
    </header>

    <section class="orbit__section prose" id="purpose">
      <h2>Purpose</h2>
      {orbit.purpose.map((paragraph) => <p>{paragraph}</p>)}
    </section>

    <section class="orbit__section prose" id="out-of-scope">
      <h2>Out of scope</h2>
      <div class="orbit-table-wrap">
        <table class="orbit-table">
          <thead>
            <tr>
              <th>Not this orbit</th>
              <th>Where it lives</th>
            </tr>
          </thead>
          <tbody>
            {
              orbit.outOfScope.map((row) => (
                <tr>
                  <td>{row.notThis}</td>
                  <td>{row.where}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    {
      orbit.enumerations.length > 0 ? (
        <section class="orbit__section prose" id="enumerations">
          <h2>Enumerations (draft — freeze later)</h2>
          <div class="orbit-table-wrap">
            <table class="orbit-table">
              <thead>
                <tr>
                  <th>Field</th>
                  <th>Allowed values (draft)</th>
                </tr>
              </thead>
              <tbody>
                {orbit.enumerations.map((row) => (
                  <tr>
                    <td>
                      <code>{row.field}</code>
                    </td>
                    <td>
                      <code>{row.values}</code>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      ) : null
    }

    <section class="orbit__section prose" id="normative-intent">
      <h2>Normative intent (when elevated from Draft)</h2>
      <ul>
        {orbit.normativeIntent.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="orbit__section prose" id="foundation-vs-archive">
      <h2>Foundation vs Archive</h2>
      <div class="orbit-table-wrap">
        <table class="orbit-table">
          <thead>
            <tr>
              <th>Foundation</th>
              <th>Archive</th>
            </tr>
          </thead>
          <tbody>
            {
              orbit.foundationVsArchive.map((row) => (
                <tr>
                  <td>{row.foundation}</td>
                  <td>{row.archive}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    <section class="orbit__section prose" id="golden-example">
      <h2>Golden example (illustrative)</h2>
      <p>
        Minimal worked example for consultation. Not a production product API.
        <a href={orbit.exampleHref} download={orbit.exampleFilename}>Download JSON</a>.
      </p>
      <pre class="orbit__code"><code>{exampleJson}</code></pre>
    </section>

    <nav class="orbit__siblings" aria-label="Other draft orbits">
      {
        STANDARDS_ORBITS.filter((item) => item.slug !== orbit.slug).map((item) => (
          <a href={item.path}>
            {item.shortName}
            <span>{item.maturityLabel}</span>
          </a>
        ))
      }
    </nav>
  </article>
</BaseLayout>

<style>
  .orbit__head {
    padding-block: clamp(2.6rem, 6vw, 4rem) 1rem;
  }

  .orbit__back {
    color: inherit;
    text-decoration: none;
  }

  .orbit__back:hover {
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .orbit__maturity {
    display: inline-block;
    margin: 0 0 0.65rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-soft);
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.15rem;
  }

  .orbit__dek {
    font-size: 1.05rem;
    color: var(--ink-muted);
    max-width: 46rem;
  }

  .orbit__banner {
    max-width: 46rem;
    margin: 1rem 0 0;
    padding: 0.75rem 0.9rem;
    font-size: 0.88rem;
    line-height: 1.45;
    color: var(--ink-soft);
    background: var(--accent-tint);
    border-inline-start: 3px solid var(--accent);
  }

  .orbit__schema {
    font-size: 0.88rem;
    color: var(--ink-muted);
  }

  .orbit__section {
    padding-block: 1.4rem 0.4rem;
  }

  .orbit__section h2 {
    font-size: 1.25rem;
  }

  .orbit-table-wrap {
    overflow-x: auto;
    margin-block: 0.85rem 0.4rem;
  }

  .orbit-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .orbit-table :global(th),
  .orbit-table :global(td) {
    border: 1px solid var(--line-soft);
    padding: 0.55rem 0.65rem;
    vertical-align: top;
    text-align: start;
  }

  .orbit-table :global(th) {
    background: var(--surface-muted, rgba(0, 0, 0, 0.03));
    font-weight: 600;
  }

  .orbit__code {
    margin: 1rem 0 0;
    padding: 1rem 1.1rem;
    overflow-x: auto;
    font-size: 0.78rem;
    line-height: 1.45;
    background: var(--paper-raised);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius);
  }

  .orbit__code code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    white-space: pre;
  }

  .orbit__siblings {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-block: 2rem 3rem;
  }

  .orbit__siblings a {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 10rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--ink);
    font-weight: 600;
  }

  .orbit__siblings a span {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--ink-muted);
  }

  .orbit__siblings a:hover {
    border-color: var(--accent);
  }
</style>
