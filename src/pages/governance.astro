---
import BaseLayout from '../layouts/BaseLayout.astro'
import DocsSection from '../components/DocsSection.astro'
import GovernanceFirewallDiagram from '../components/GovernanceFirewallDiagram.astro'
import StandardMaturityDiagram from '../components/StandardMaturityDiagram.astro'
import { buildFoundationGovernanceSections } from '../data/governanceContent.js'
import { SITE_NAV_LINKS } from '../data/site.js'

const sections = buildFoundationGovernanceSections()
---

<BaseLayout
  title="Governance"
  description="Governance of the open landscape metadata standard — Foundation Standards, three-entity structure, truth-telling, licence, and interim stewardship."
  path="/governance"
>
  <div class="page gov">
    <div class="gov__intro prose">
      <h1>Governance</h1>
      <p>
        Intended stewardship of the open landscape metadata specification: three-entity
        structure, Foundation Standards, licence, and interim stewardship. Draft terms for
        consultation only.
      </p>
    </div>

    <nav class="gov__toc" aria-label="On this page">
      {sections.map((section) => <a href={`#${section.id}`}>{section.heading}</a>)}
    </nav>

    <GovernanceFirewallDiagram />
    <StandardMaturityDiagram />

    {sections.map((section) => <DocsSection {...section} sharePagePath="/governance" />)}
  </div>
</BaseLayout>

<style>
  .gov__intro {
    padding-block: clamp(2.6rem, 6vw, 4rem) 1rem;
  }

  .gov__toc {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.9rem;
    padding: 1.1rem 0 0.4rem;
    margin-bottom: 0.5rem;
    border-block: 1px solid var(--line-soft);
  }

  .gov__toc a {
    font-size: 0.8rem;
    color: var(--ink-muted);
    text-decoration: none;
  }

  .gov__toc a:hover {
    color: var(--accent-strong);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }
</style>
