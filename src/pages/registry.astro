---
import BaseLayout from '../layouts/BaseLayout.astro'
import SectionShareLinks from '../components/SectionShareLinks.astro'
import preview from '../data/tla185-fields-preview.json'
import LicenceNotice from '../components/LicenceNotice.astro'
import {
  OPEN_STANDARD_GITHUB_TAG_URL,
  OPEN_STANDARD_GITHUB_UNAVAILABLE_NOTICE,
  FEDERATION_SCHEMA_PORTAL_URL,
  ADOPT_PATH,
  TLA185_DISPLAY_ID,
  TLA185_FIELD_COUNT,
  isOpenStandardGithubPubliclyAvailable
} from '../data/foundationWing.js'
import { SCHEMA_PORTAL_URL } from '../data/site.js'

const DICTIONARY_URL = `${SCHEMA_PORTAL_URL}/dictionary`
const githubAvailable = isOpenStandardGithubPubliclyAvailable()

const modules = preview.modules ?? []
const fields = preview.fields ?? []

// Group the preview fields by module for a scannable, module-rail layout.
const fieldsByModule = new Map<string, typeof fields>()
for (const field of fields) {
  const list = fieldsByModule.get(field.module) ?? []
  list.push(field)
  fieldsByModule.set(field.module, list)
}
---

<BaseLayout
  title="Field registry"
  description={`A public preview of the ${TLA185_DISPLAY_ID} field registry — ${TLA185_FIELD_COUNT} documented elements across taxonomy, site context, climate screening, sustainability, cultural context, and BIM delivery.`}
  path="/registry"
>
  <div class="page reg">
    <div class="reg__intro prose">
      <p class="eyebrow">{preview.standardLabel}</p>
      <h1>{TLA185_DISPLAY_ID} field registry</h1>
      <p class="reg__quickstart" role="note">
        <strong>First visit?</strong>
        Follow the <a href={ADOPT_PATH}>adoption quickstart</a> — download the open pack, validate an
        example bundle, and add the procurement sentence to one deliverable. No account required. The
        Foundation operates under interim stewardship; the specification and tooling are public reference
        infrastructure.
      </p>
      <p>
        The published specification describes <strong>{TLA185_FIELD_COUNT} documented elements</strong>
        across {modules.length} modules — structural definitions only, with no species inventories,
        trait values, or client records. Below is a public preview of {fields.length} representative
        fields. The full, searchable <a href={DICTIONARY_URL} rel="noopener" target="_blank">Landscape Data
        Dictionary</a> — every term with a definition, a stable citable identifier, and a way to propose a
        change — plus JSON Schema modules and worked examples live on the schema portal{
          githubAvailable ? ' and GitHub' : ''
        }.
      </p>
      {
        !githubAvailable && (
          <p class="reg__github-notice" role="note">{OPEN_STANDARD_GITHUB_UNAVAILABLE_NOTICE}</p>
        )
      }
      <div class="action-row">
        <a class="btn btn--primary" href={ADOPT_PATH}>Adoption quickstart</a>
        <a class="btn" href={DICTIONARY_URL} rel="noopener" target="_blank">
          Full Data Dictionary <span class="btn__ext" aria-hidden="true">↗</span>
        </a>
        {
          githubAvailable && (
            <a class="btn" href={OPEN_STANDARD_GITHUB_TAG_URL} rel="noopener" target="_blank">
              Canonical specification <span class="btn__ext" aria-hidden="true">↗</span>
            </a>
          )
        }
        <a class="btn" href={FEDERATION_SCHEMA_PORTAL_URL} rel="noopener" target="_blank">
          Schema portal <span class="btn__ext" aria-hidden="true">↗</span>
        </a>
      </div>
    </div>

    <div class="reg__modules">
      {
        modules.map((mod) => (
          <div class="reg__module">
            <span class="reg__module-count">{mod.totalFieldCount}</span>
            <span class="reg__module-label">{mod.label}</span>
            <span class="reg__module-since">{mod.introducedIn}</span>
          </div>
        ))
      }
    </div>

    <div class="reg__fields">
      {
        modules
          .filter((mod) => (fieldsByModule.get(mod.id) ?? []).length > 0)
          .map((mod) => (
            <section class="reg__group" id={`module-${mod.id}`}>
              <h2 class="reg__group-head">{mod.label}</h2>
              <div class="reg__cards">
                {(fieldsByModule.get(mod.id) ?? []).map((field) => (
                  <article class="reg__card">
                    <header class="reg__card-head">
                      <code class="reg__key">{field.key}</code>
                      <span class="reg__type">{field.type}</span>
                    </header>
                    <h3 class="reg__card-title">{field.label}</h3>
                    <p class="reg__card-desc">{field.description}</p>
                    <footer class="reg__card-foot">
                      <code>{field.jsonPath}</code>
                      {field.required && <span class="reg__req">required</span>}
                    </footer>
                  </article>
                ))}
              </div>
              <SectionShareLinks
                pagePath="/registry"
                anchorId={`module-${mod.id}`}
                title={`${mod.label} — field registry`}
              />
            </section>
          ))
      }
    </div>

    <LicenceNotice />

    <p class="reg__note">
      Preview generated from the published registry. Field IDs, JSON paths, and module structure are
      stable; values and populated datasets are licensed separately and are not part of the open layer.
    </p>
  </div>
</BaseLayout>

<style>
  .reg__intro {
    padding-block: clamp(2.6rem, 6vw, 4rem) 1.5rem;
  }

  .reg__quickstart {
    padding: 0.85rem 1rem;
    margin: 0 0 1.25rem;
    border: 1px solid var(--line);
    border-left: 4px solid var(--accent-strong);
    background: var(--paper-raised);
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  .reg__github-notice {
    margin: 1rem 0 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: var(--measure);
  }

  .reg__modules {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr));
    gap: 0.6rem;
    padding-block: 1.5rem;
    border-block: 1px solid var(--line-soft);
  }

  .reg__module {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: 0.6rem;
    align-items: baseline;
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-sm);
    background: var(--paper-raised);
  }

  .reg__module-count {
    grid-row: 1 / 3;
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--accent);
  }

  .reg__module-label {
    font-size: 0.86rem;
    font-weight: 500;
    color: var(--ink);
  }

  .reg__module-since {
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .reg__group {
    padding-block: 2rem 0.5rem;
  }

  .reg__group-head {
    font-size: 1.2rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--line-soft);
  }

  .reg__cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 1rem;
    margin-top: 1.2rem;
  }

  .reg__card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper-raised);
  }

  .reg__card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  .reg__key {
    font-size: 0.82rem;
    color: var(--accent-strong);
    background: var(--accent-tint);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
  }

  .reg__type {
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .reg__card-title {
    font-family: var(--font-sans);
    font-size: 0.98rem;
    font-weight: 600;
    margin: 0;
  }

  .reg__card-desc {
    margin: 0;
    font-size: 0.85rem;
    color: var(--ink-soft);
    flex: 1;
  }

  .reg__card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--line-soft);
  }

  .reg__card-foot code {
    font-size: 0.74rem;
    color: var(--ink-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .reg__req {
    flex-shrink: 0;
    font-size: 0.64rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-strong);
  }

  .reg__note {
    margin: 2.5rem 0 0;
    padding-top: 1.2rem;
    border-top: 1px solid var(--line-soft);
    font-size: 0.8rem;
    color: var(--ink-muted);
    max-width: var(--measure);
  }
</style>
