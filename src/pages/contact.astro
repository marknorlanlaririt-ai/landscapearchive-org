---
import BaseLayout from '../layouts/BaseLayout.astro'
import DocsSection from '../components/DocsSection.astro'
import DraftConsultationForm from '../components/DraftConsultationForm.astro'
import { buildFoundationContactSections, FOUNDATION_CONTACT_EMAIL } from '../data/contactContent.js'
---

<BaseLayout
  title="Contact"
  description="Contact routes for The Landscape Archive Foundation — open standard stewardship, draft consultation review packs, commercial licensing handoffs, press, and voluntary support."
  path="/contact"
>
  <div class="page contact">
    <div class="contact__intro prose">
      <h1>Contact</h1>
      <p>
        Open standard, governance, registry, licensing, and press. Operational
        correspondence is handled through the interim Archive desk.
      </p>
      <p class="contact__email">
        Email:
        <a href={`mailto:${FOUNDATION_CONTACT_EMAIL}`}>{FOUNDATION_CONTACT_EMAIL}</a>
      </p>
    </div>

    {buildFoundationContactSections().map((section) => <DocsSection {...section} />)}

    <DraftConsultationForm />
  </div>
</BaseLayout>

<style>
  .contact__intro {
    padding-block: clamp(2.6rem, 6vw, 4rem) 0.5rem;
  }

  .contact__email {
    margin-top: 1rem;
    font-size: 0.95rem;
    color: var(--ink-soft);
  }

  .contact__email a {
    color: var(--accent-strong);
    font-weight: 600;
  }
</style>
