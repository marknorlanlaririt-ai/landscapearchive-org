---
import BaseLayout from '../layouts/BaseLayout.astro'
import DocsSection from '../components/DocsSection.astro'
import VolunteerApplicationForm from '../components/VolunteerApplicationForm.astro'
import { foundationTopicPages } from '../data/topicPages.js'
import { isMemberOnlyOrgPath } from '../data/memberAccess.js'

export function getStaticPaths() {
  return Object.values(foundationTopicPages).map((page) => ({
    params: { topic: page.slug },
    props: { page }
  }))
}

const { page } = Astro.props
const pagePath = `/${page.slug}`
const memberOnly = isMemberOnlyOrgPath(pagePath)
const showVolunteerApplication = page.slug === 'volunteers'
---

<BaseLayout title={page.title} description={page.lead} path={pagePath} noindex={memberOnly}>
  <div class="page topic" data-member-only-page={memberOnly ? '' : undefined}>
    <div class="topic__intro prose">
      <h1>{page.title}</h1>
      {
        page.statusBanner && (
          <aside class="topic__status-banner" role="status" aria-label="Programme status">
            <p class="topic__status-banner-title">{page.statusBanner.title}</p>
            <p class="topic__status-banner-body">{page.statusBanner.body}</p>
          </aside>
        )
      }
      {page.lead && !page.hideLead && <p class="topic__lead">{page.lead}</p>}
      {page.placeholder && <p class="topic__flag">In preparation.</p>}
    </div>

    {page.sections.map((section) => <DocsSection {...section} sharePagePath={pagePath} />)}

    {showVolunteerApplication && <VolunteerApplicationForm />}
  </div>
</BaseLayout>

<style>
  .topic__intro {
    padding-block: clamp(2.6rem, 6vw, 4rem) 0.5rem;
  }

  .topic__lead {
    font-size: 1.15rem;
    color: var(--ink-soft);
  }

  .topic__status-banner {
    margin: 1.25rem 0 1.5rem;
    padding: 1.35rem 1.4rem 1.45rem;
    border: 2px solid var(--ink);
    background: var(--paper-raised);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.04);
  }

  .topic__status-banner-title {
    margin: 0 0 0.65rem;
    font-size: clamp(1.05rem, 2.4vw, 1.35rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.25;
    text-transform: uppercase;
    color: var(--ink);
  }

  .topic__status-banner-body {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  .topic__flag {
    display: inline-block;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-strong);
    background: transparent;
    padding: 0.15rem 0;
    border-bottom: 1px solid var(--line);
    border-radius: 0;
  }
</style>
