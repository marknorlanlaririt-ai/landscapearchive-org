---
import BaseLayout from '../../layouts/BaseLayout.astro'
import FieldNotesMemberBody from '../../components/FieldNotesMemberBody.astro'
import {
  PUBLISHED_FIELD_NOTES,
  getArticlePreviewExcerpt,
  formatArticleDate
} from '../../data/articles.js'
import { SCHEMA_PORTAL_URL } from '../../data/site.js'

export function getStaticPaths() {
  return PUBLISHED_FIELD_NOTES.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }))
}

const { article } = Astro.props

const articlePath = `/articles/${article.slug}`
const articleUrl = new URL(articlePath, Astro.site ?? 'https://landscapearchive.org').toString()
const previewExcerpt = getArticlePreviewExcerpt(article)

// Teaser structured data — indexable preview; full body is member-unlocked client-side.
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.dek,
  url: articleUrl,
  mainEntityOfPage: articleUrl,
  datePublished: article.date,
  author: { '@type': 'Organization', name: article.author },
  isAccessibleForFree: false,
  hasPart: {
    '@type': 'WebPageElement',
    isAccessibleForFree: true,
    cssSelector: '.essay__preview'
  },
  publisher: {
    '@type': 'Organization',
    name: 'The Landscape Archive Foundation',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/tla-foundation-mark.svg', Astro.site ?? 'https://landscapearchive.org').toString()
    }
  }
}
---

<BaseLayout title={article.title} description={article.dek} path={articlePath}>
  <article class="page essay">
    <div class="essay__head prose">
      <p class="eyebrow"><a class="essay__back" href="/articles">Field Notes</a></p>
      <h1>{article.title}</h1>
      <p class="essay__dek">{article.dek}</p>
      <p class="essay__byline">
        {article.author} · {formatArticleDate(article.date)}
        {article.readingTime && <span> · {article.readingTime}</span>}
      </p>
      {
        article.topics && (
          <div class="essay__topics">
            {article.topics.map((topic) => <span class="essay__topic">{topic}</span>)}
          </div>
        )
      }
    </div>

    <div class="essay__preview prose">
      <p>{previewExcerpt}</p>
    </div>

    <FieldNotesMemberBody slug={article.slug} articlePath={articlePath} />

    <footer class="essay__foot">
      {
        article.legalNote && (
          <p class="essay__legal-note" data-field-notes-legal hidden>{article.legalNote}</p>
        )
      }
      <p>
        Published by The Landscape Archive Foundation under
        <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" rel="noopener" target="_blank">
          CC BY-NC-ND 4.0</a>. Cite with the title and this page URL. Open grammar (
        <a href={`${SCHEMA_PORTAL_URL}/dictionary`} rel="noopener">field dictionary</a>
        ) remains publicly citable.
      </p>
      <p><a href="/articles">← All Field Notes</a></p>
    </footer>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} is:inline />

  <script is:inline>
    (function () {
      function syncLegal() {
        var loggedIn = document.documentElement.dataset.archiveLoggedIn === 'true'
        document.querySelectorAll('[data-field-notes-legal]').forEach(function (el) {
          el.hidden = !loggedIn
        })
      }
      syncLegal()
      window.setInterval(syncLegal, 1200)
    })()
  </script>
</BaseLayout>

<style>
  .essay {
    max-width: 46rem;
  }

  .essay__head {
    padding-block: clamp(2.6rem, 6vw, 4rem) 0.5rem;
  }

  .essay__back {
    color: var(--accent-strong);
    text-decoration: none;
  }

  .essay__dek {
    font-size: 1.2rem;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  .essay__byline {
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    color: var(--ink-muted);
  }

  .essay__topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.6rem;
  }

  .essay__topic {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-strong);
    background: transparent;
    padding: 0.1rem 0;
    border-bottom: 1px solid var(--line);
    border-radius: 0;
  }

  .essay__preview {
    margin-top: 1.4rem;
    color: var(--ink-soft);
  }

  .essay__preview p {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .essay__foot {
    margin-top: 2.5rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--line-soft);
    font-size: 0.85rem;
    color: var(--ink-muted);
  }

  .essay__legal-note {
    font-size: 0.82rem;
    line-height: 1.55;
    padding: 0.85rem 1rem;
    margin-bottom: 1rem;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-sm);
    background: var(--paper-raised);
  }

  .essay__foot a {
    color: var(--accent-strong);
  }
</style>
