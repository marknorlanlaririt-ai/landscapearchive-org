---
import BaseLayout from '../layouts/BaseLayout.astro'
import DocsSection from '../components/DocsSection.astro'
import RecentUpdatesStrip from '../components/RecentUpdatesStrip.astro'
import SectionShareLinks from '../components/SectionShareLinks.astro'
import TlaLettermark from '../components/TlaLettermark.astro'
import DirectorEasterEgg from '../components/DirectorEasterEgg.astro'
import { buildFoundationHomeSections } from '../data/homeContent.js'
import { FOUNDATION_CHARTER_PILLARS, FOUNDATION_PILLARS_LABEL } from '../data/charterPillars.js'
import {
  GOVERNANCE_PATH,
  REGISTRY_PATH,
  ADOPT_PATH,
  TLA185_DISPLAY_ID,
  TLA185_FIELD_COUNT,
  FOUNDATION_LICENCE_LABEL,
  FEDERATION_SCHEMA_PORTAL_URL
} from '../data/foundationWing.js'
import { SITE_DESCRIPTION, SITE_TAGLINE } from '../data/site.js'

const sections = buildFoundationHomeSections()
---

<BaseLayout
  title="The Landscape Archive Foundation"
  description={SITE_DESCRIPTION}
  path="/"
>
  <section class="hero">
    <div class="page hero__inner">
      <TlaLettermark class="hero__mark" size={72} title="The Landscape Archive Foundation" />
      <p class="hero__tagline">{SITE_TAGLINE}</p>
      <h1 class="hero__title">Steward of the open landscape metadata specification.</h1>
      <p class="hero__lead">
        The Landscape Archive Foundation publishes <strong>{TLA185_DISPLAY_ID}</strong>
        ({TLA185_FIELD_COUNT} documented elements) under {FOUNDATION_LICENCE_LABEL}: field
        registry, schemas, and conformance criteria for botanical, climate, sustainability,
        cultural, and synthetic-nature claims in project records.
      </p>
      <div class="action-row">
        <a class="btn btn--primary" href={GOVERNANCE_PATH}>Governance</a>
        <a class="btn" href={REGISTRY_PATH}>Field registry</a>
        <a class="btn" href="/licence">Licence &amp; scope</a>
        <a class="btn" href={`${FEDERATION_SCHEMA_PORTAL_URL}/dictionary`} rel="noopener">
          Field dictionary
        </a>
        <a class="btn" href={ADOPT_PATH}>Adoption</a>
      </div>
    </div>
  </section>

  <RecentUpdatesStrip />

  <div class="page">
    {sections.map((section) => <DocsSection {...section} sharePagePath="/" />)}

    <section class="section-block" id="foundation-pillars" aria-label={FOUNDATION_PILLARS_LABEL}>
      <div class="prose">
        <h2>{FOUNDATION_PILLARS_LABEL}</h2>
        <p>
          Five domains of public reference work. Shared definitions and open governance mark the
          boundary between the public specification and commercial implementation.
        </p>
      </div>
      <ol class="pillars">
        {
          FOUNDATION_CHARTER_PILLARS.map((pillar, index) => (
            <li class="pillar">
              <span class="pillar__num">{String(index + 1).padStart(2, '0')}</span>
              <h3 class="pillar__title">{pillar.title}</h3>
              <p class="pillar__desc">{pillar.description}</p>
            </li>
          ))
        }
      </ol>
      <div class="action-row">
        <a class="btn" href={GOVERNANCE_PATH}>Full standards text</a>
      </div>
      <SectionShareLinks pagePath="/" anchorId="foundation-pillars" title={FOUNDATION_PILLARS_LABEL} />
    </section>
  </div>

  <DirectorEasterEgg />
</BaseLayout>

<style>
  .hero {
    border-bottom: 1px solid var(--line-soft);
    background: var(--paper);
  }

  .hero__inner {
    padding-block: clamp(3rem, 8vw, 6rem) clamp(2.4rem, 5vw, 4rem);
    max-width: 48rem;
  }

  .hero__mark {
    width: 72px;
    height: 72px;
    margin-bottom: 1.4rem;
  }

  .hero__tagline {
    margin: 0 0 0.65rem;
    max-width: 28rem;
    font-family: var(--font-sans);
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    font-weight: 500;
    line-height: 1.45;
    letter-spacing: 0.01em;
    color: var(--accent-strong);
  }

  .hero__title {
    font-size: clamp(2.1rem, 5vw, 3.2rem);
    max-width: 18ch;
  }

  .hero__lead {
    font-size: clamp(1.02rem, 1.8vw, 1.2rem);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 38rem;
  }

  .pillars {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1.5rem;
  }

  .pillar {
    padding: 1.5rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper-raised);
  }

  .pillar__num {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--accent);
  }

  .pillar__title {
    font-size: 1.1rem;
    margin: 0.5rem 0 0.5rem;
  }

  .pillar__desc {
    margin: 0;
    font-size: 0.9rem;
    color: var(--ink-soft);
  }
</style>
