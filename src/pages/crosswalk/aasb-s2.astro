---
import BaseLayout from '../../layouts/BaseLayout.astro'
import SectionShareLinks from '../../components/SectionShareLinks.astro'
import { readFileSync } from 'node:fs'
import { fileURLToPath } from 'node:url'
import { TLA185_DISPLAY_ID } from '../../data/foundationWing.js'

const pagePath = '/crosswalk/aasb-s2'
const markdownPath = fileURLToPath(new URL('../../../public/crosswalk/aasb-s2-tla185-mapping.md', import.meta.url))
const rawMarkdown = readFileSync(markdownPath, 'utf8')

/** Minimal markdown → HTML for static crosswalk tables (build-time only). */
function renderCrosswalkMarkdown(source) {
  const lines = source.split(/\r?\n/)
  const out = []
  let inTable = false
  let tableRows = []

  const flushTable = () => {
    if (!tableRows.length) return
    out.push('<div class="crosswalk-table-wrap"><table class="crosswalk-table">')
    tableRows.forEach((row, index) => {
      const tag = index === 0 ? 'th' : 'td'
      const cells = row
        .split('|')
        .slice(1, -1)
        .map((cell) => cell.trim())
      if (cells.every((cell) => /^[-:\s]+$/.test(cell))) return
      out.push('<tr>')
      cells.forEach((cell) => {
        const html = inlineMarkdown(cell)
        out.push(`<${tag}>${html}</${tag}>`)
      })
      out.push('</tr>')
    })
    out.push('</table></div>')
    tableRows = []
    inTable = false
  }

  const inlineMarkdown = (text) =>
    text
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')

  for (const line of lines) {
    if (line.startsWith('# ')) continue
    if (line.startsWith('## ')) {
      flushTable()
      out.push(`<h2>${inlineMarkdown(line.slice(3))}</h2>`)
      continue
    }
    if (line.startsWith('### ')) {
      flushTable()
      out.push(`<h3>${inlineMarkdown(line.slice(4))}</h3>`)
      continue
    }
    if (line.startsWith('|')) {
      inTable = true
      tableRows.push(line)
      continue
    }
    if (inTable) flushTable()
    if (line.trim() === '---') {
      out.push('<hr />')
      continue
    }
    if (line.startsWith('> ')) {
      out.push(`<blockquote><p>${inlineMarkdown(line.slice(2))}</p></blockquote>`)
      continue
    }
    if (line.trim()) {
      out.push(`<p>${inlineMarkdown(line)}</p>`)
    }
  }
  flushTable()
  return out.join('\n')
}

const bodyHtml = renderCrosswalkMarkdown(rawMarkdown)
---

<BaseLayout
  title="AASB S2 crosswalk"
  description={`Concept crosswalk from ${TLA185_DISPLAY_ID} screening fields to AASB S2 climate-related disclosure areas — supporting input for physical-risk and resilience narratives, not statutory filing.`}
  path={pagePath}
>
  <article class="page crosswalk">
    <div class="crosswalk__head prose">
      <p class="eyebrow"><a class="crosswalk__back" href="/governance#international-adoption">Governance · International adoption</a></p>
      <h1>TLA-185 → AASB S2 concept crosswalk</h1>
      <p class="crosswalk__dek">
        Australian climate-disclosure analogue. Maps open specification field identifiers to commonly encountered
        AASB S2 concepts for procurement and assurance review — same structural slots as the UK IFRS S2 crosswalk,
        with Australian jurisdiction notes in the source document.
      </p>
      <p class="crosswalk__meta">
        Concept mapping only — not legal or assurance advice. Not a GHG inventory, not a statutory certificate, and
        not a claim that landscape metadata alone satisfies AASB S2 filings. Verify current ASIC / AASB guidance
        before client delivery.
      </p>
      <SectionShareLinks
        title="TLA-185 → AASB S2 concept crosswalk"
        pagePath={pagePath}
        anchorId="aasb-s2"
      />
    </div>

    <div class="crosswalk__body prose" set:html={bodyHtml} />

    <p class="crosswalk__download">
      <a href="/crosswalk/aasb-s2-tla185-mapping.md">Download markdown source</a>
    </p>
  </article>
</BaseLayout>

<style>
  .crosswalk__head {
    padding-block: clamp(2.6rem, 6vw, 4rem) 1rem;
  }

  .crosswalk__back {
    color: inherit;
    text-decoration: none;
  }

  .crosswalk__back:hover {
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .crosswalk__dek {
    font-size: 1.05rem;
    color: var(--ink-muted);
    max-width: 46rem;
  }

  .crosswalk__meta {
    font-size: 0.88rem;
    color: var(--ink-muted);
  }

  .crosswalk__body :global(h2) {
    margin-top: 2.2rem;
    font-size: 1.35rem;
  }

  .crosswalk__body :global(h3) {
    margin-top: 1.4rem;
    font-size: 1.05rem;
  }

  .crosswalk__body :global(blockquote) {
    border-inline-start: 3px solid var(--accent-soft);
    padding-inline-start: 1rem;
    color: var(--ink-muted);
  }

  .crosswalk-table-wrap {
    overflow-x: auto;
    margin-block: 1rem 1.4rem;
  }

  .crosswalk-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .crosswalk-table :global(th),
  .crosswalk-table :global(td) {
    border: 1px solid var(--line-soft);
    padding: 0.55rem 0.65rem;
    vertical-align: top;
    text-align: start;
  }

  .crosswalk-table :global(th) {
    background: var(--surface-muted, rgba(0, 0, 0, 0.03));
    font-weight: 600;
  }

  .crosswalk__download {
    padding-block: 2rem 3rem;
    font-size: 0.88rem;
  }
</style>
