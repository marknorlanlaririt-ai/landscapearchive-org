---
import SectionShareLinks from './SectionShareLinks.astro'

// Renders one editorial content section: heading, paragraphs, bullets,
// a fact list (optionally collapsible via native <details>), and actions.
function slugifyHeading(text: string): string {
  return text
    .replace(/<[^>]*>/g, '')
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '')
}

interface Action {
  label: string
  href: string
  external?: boolean
}
interface Fact {
  label: string
  value: string
}
interface ProfileRow {
  label: string
  targetFormat: string
  purpose: string
  status: string
  schemaUrl: string
}
interface Props {
  id?: string
  heading?: string
  paragraphs?: string[]
  bullets?: string[]
  facts?: Fact[]
  factsCollapsible?: boolean
  factsToggleLabel?: string
  profileTable?: ProfileRow[]
  actions?: Action[]
  /** Optional copy-paste block (e.g. studio brief). */
  plainText?: string
  plainTextLabel?: string
  /** When set, renders a share row after this section (public Foundation pages only). */
  sharePagePath?: string
}
const {
  id,
  heading,
  paragraphs = [],
  bullets = [],
  facts = [],
  factsCollapsible = false,
  factsToggleLabel = 'Show details',
  profileTable = [],
  actions = [],
  plainText,
  plainTextLabel = 'Copy-paste text',
  sharePagePath
} = Astro.props

const sectionAnchorId = id ?? (heading ? slugifyHeading(heading) : undefined)
const shareTitle = heading ?? 'This section'
---

<section id={sectionAnchorId} class="section-block">
  <div class="prose">
    {heading && <h2>{heading}</h2>}
    {paragraphs.map((text) => <p set:html={text} />)}

    {
      bullets.length > 0 && (
        <ul class="bullet-list">
          {bullets.map((item) => (
            <li set:html={item} />
          ))}
        </ul>
      )
    }

    {
      profileTable.length > 0 && (
        <div class="profile-table-wrap">
          <table class="profile-table">
            <thead>
              <tr>
                <th scope="col">Interchange profile</th>
                <th scope="col">Target format</th>
                <th scope="col">Purpose</th>
                <th scope="col">Status</th>
              </tr>
            </thead>
            <tbody>
              {profileTable.map((row) => (
                <tr>
                  <th scope="row">
                    <a href={row.schemaUrl}>{row.label}</a>
                  </th>
                  <td>{row.targetFormat}</td>
                  <td>{row.purpose}</td>
                  <td>
                    <span class:list={['profile-table__status', `profile-table__status--${row.status.toLowerCase()}`]}>
                      {row.status}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )
    }

    {
      facts.length > 0 &&
        (factsCollapsible ? (
          <details class="fact-details">
            <summary>{factsToggleLabel}</summary>
            <dl class="fact-list">
              {facts.map((fact) => (
                <div class="fact-list__row">
                  <dt class="fact-list__label">{fact.label}</dt>
                  <dd class="fact-list__value">{fact.value}</dd>
                </div>
              ))}
            </dl>
          </details>
        ) : (
          <dl class="fact-list">
            {facts.map((fact) => (
              <div class="fact-list__row">
                <dt class="fact-list__label">{fact.label}</dt>
                <dd class="fact-list__value">{fact.value}</dd>
              </div>
            ))}
          </dl>
        ))
    }

    {
      plainText && (
        <pre class="docs-plain-text" aria-label={plainTextLabel}>
          {plainText}
        </pre>
      )
    }

    {
      actions.length > 0 && (
        <div class="action-row">
          {actions.map((action, index) => (
            <a
              href={action.href}
              class:list={['btn', { 'btn--primary': index === 0 }]}
              rel={action.external ? 'noopener' : undefined}
              target={action.external ? '_blank' : undefined}
            >
              {action.label}
              {action.external && <span class="btn__ext" aria-hidden="true">↗</span>}
            </a>
          ))}
        </div>
      )
    }

    {
      sharePagePath && (
        <SectionShareLinks
          pagePath={sharePagePath}
          anchorId={sectionAnchorId}
          title={shareTitle}
        />
      )
    }
  </div>
</section>

<style>
  .fact-list dt,
  .fact-list dd {
    margin: 0;
  }

  .fact-details {
    margin-top: 1.2rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--paper-raised);
    padding: 0 1rem;
  }

  .fact-details > summary {
    cursor: pointer;
    padding: 0.85rem 0;
    font-weight: 600;
    color: var(--accent-strong);
    list-style-position: inside;
  }

  .fact-details[open] > summary {
    border-bottom: 1px solid var(--line-soft);
  }

  .fact-details .fact-list {
    margin: 0 0 0.8rem;
    border-top: 0;
  }

  .profile-table-wrap {
    margin-top: 1.2rem;
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--paper-raised);
  }

  .profile-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
  }

  .profile-table th,
  .profile-table td {
    padding: 0.65rem 0.85rem;
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--line-soft);
  }

  .profile-table thead th {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-muted);
    background: var(--accent-tint);
  }

  .profile-table tbody tr:last-child th,
  .profile-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .profile-table tbody th {
    font-weight: 600;
    white-space: nowrap;
  }

  .profile-table td:last-child {
    width: 1%;
    white-space: nowrap;
    vertical-align: middle;
  }

  .profile-table__status {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    font-variant: all-small-caps;
    letter-spacing: 0.08em;
    line-height: 1;
    padding: 0.28rem 0.55rem;
    border-radius: 2px;
    border: 1px solid var(--line);
    background: var(--paper);
    color: var(--ink-muted);
  }

  .profile-table__status--mvp {
    border-color: rgba(52, 61, 74, 0.4);
    color: var(--accent-strong);
    background: rgba(52, 61, 74, 0.06);
  }

  .profile-table__status--draft {
    border-style: dashed;
    border-color: var(--line);
    color: var(--ink-muted);
    background: transparent;
  }

  .docs-plain-text {
    margin-top: 1.2rem;
    padding: 1rem 1.1rem;
    max-height: 28rem;
    overflow: auto;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--paper-raised);
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    line-height: 1.55;
    white-space: pre-wrap;
    word-break: break-word;
    color: var(--ink-soft);
  }
</style>
