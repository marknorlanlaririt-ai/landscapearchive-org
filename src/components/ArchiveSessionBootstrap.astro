---
import {
  ARCHIVE_SESSION_VERIFY_URL,
  ARCHIVE_ORG_ACCESS_VERIFY_URL,
  ARCHIVE_FOUNDATION_SIGN_OUT_URL,
  MEMBER_ONLY_ORG_PATHS,
  ORG_SIGN_IN_PATH,
  SESSION_HANDOFF_ORG_PATHS
} from '../data/memberAccess.js'
---

<script is:inline define:vars={{ ARCHIVE_SESSION_VERIFY_URL, ARCHIVE_ORG_ACCESS_VERIFY_URL, ARCHIVE_FOUNDATION_SIGN_OUT_URL, MEMBER_ONLY_ORG_PATHS, ORG_SIGN_IN_PATH, SESSION_HANDOFF_ORG_PATHS }}>
  (function () {
    var ORG_ACCESS_STORAGE_KEY = 'la-foundation-org-access'

    function normalizePath(path) {
      return String(path || '').replace(/\/+$/, '') || '/'
    }

    function isMemberOnlyPath(path) {
      return MEMBER_ONLY_ORG_PATHS.indexOf(normalizePath(path)) >= 0
    }

    function setSessionChrome(loggedIn, email) {
      document.querySelectorAll('[data-session-chrome]').forEach(function (el) {
        el.hidden = !loggedIn
      })
      document.querySelectorAll('[data-session-guest]').forEach(function (el) {
        el.hidden = loggedIn
      })
      document.querySelectorAll('[data-session-email]').forEach(function (el) {
        el.textContent = email ? ('Signed in as ' + email) : 'Signed in'
      })
      document.querySelectorAll('[data-sign-in-status]').forEach(function (el) {
        if (!email || normalizePath(window.location.pathname) !== ORG_SIGN_IN_PATH) {
          el.hidden = true
          return
        }
        el.hidden = false
        el.textContent = 'Signed in as ' + email + '. Member programme pages are now available in the navigation.'
      })
    }

    function applyLoggedOutState() {
      document.documentElement.dataset.archiveLoggedIn = 'false'
      document.querySelectorAll('[data-member-only]').forEach(function (el) {
        el.hidden = true
      })
      setSessionChrome(false, '')
      if (isMemberOnlyPath(window.location.pathname)) {
        window.location.replace('/governance')
      }
    }

    function applyLoggedInState(email) {
      document.documentElement.dataset.archiveLoggedIn = 'true'
      document.querySelectorAll('[data-member-only]').forEach(function (el) {
        el.hidden = false
      })
      setSessionChrome(true, email || '')
    }

    function readStoredOrgAccess() {
      try {
        var raw = sessionStorage.getItem(ORG_ACCESS_STORAGE_KEY)
        if (!raw) {
          return null
        }
        var data = JSON.parse(raw)
        if (!data || !data.token || !data.expiresAt || Number(data.expiresAt) <= Date.now()) {
          sessionStorage.removeItem(ORG_ACCESS_STORAGE_KEY)
          return null
        }
        return data
      } catch (error) {
        return null
      }
    }

    function writeStoredOrgAccess(token, expiresAt, path, email) {
      try {
        sessionStorage.setItem(ORG_ACCESS_STORAGE_KEY, JSON.stringify({
          token: token,
          expiresAt: Number(expiresAt),
          path: path || ORG_SIGN_IN_PATH,
          email: String(email || '').trim()
        }))
      } catch (error) {}
    }

    function clearStoredOrgAccess() {
      try {
        sessionStorage.removeItem(ORG_ACCESS_STORAGE_KEY)
      } catch (error) {}
    }

    function stripOrgAccessTokenFromUrl() {
      var url = new URL(window.location.href)
      if (!url.searchParams.has('la_org_access')) {
        return
      }
      url.searchParams.delete('la_org_access')
      window.history.replaceState({}, '', url.pathname + url.search + url.hash)
    }

    function resolveVerifyPath(currentPath, storedPath) {
      if (storedPath) {
        return normalizePath(storedPath)
      }
      if (isMemberOnlyPath(currentPath)) {
        return normalizePath(currentPath)
      }
      return ORG_SIGN_IN_PATH
    }

    function verifyOrgAccessToken(path, token, storedPath) {
      var verifyUrl = new URL(ARCHIVE_ORG_ACCESS_VERIFY_URL)
      verifyUrl.searchParams.set('token', token)
      verifyUrl.searchParams.set('path', resolveVerifyPath(path, storedPath))
      return fetch(verifyUrl.toString(), {
        method: 'GET',
        credentials: 'include',
        cache: 'no-store',
        headers: { accept: 'application/json' }
      })
        .then(function (response) {
          return response.json().catch(function () { return {} })
        })
        .then(function (body) {
          if (body && body.valid) {
            writeStoredOrgAccess(
              token,
              body.expiresAt || Date.now() + 12 * 60 * 60 * 1000,
              body.path || storedPath || ORG_SIGN_IN_PATH,
              body.email || ''
            )
            applyLoggedInState(body.email || '')
            stripOrgAccessTokenFromUrl()
            return true
          }
          return false
        })
        .catch(function () {
          return false
        })
    }

    function verifyArchiveSession() {
      return fetch(ARCHIVE_SESSION_VERIFY_URL, {
        method: 'GET',
        credentials: 'include',
        cache: 'no-store',
        headers: { accept: 'application/json' }
      })
        .then(function (response) {
          return response.json().catch(function () { return {} })
        })
        .then(function (body) {
          if (body && body.loggedIn) {
            applyLoggedInState(body.email || body.displayName || '')
            return true
          }
          return false
        })
        .catch(function () {
          return false
        })
    }

    function signOut() {
      clearStoredOrgAccess()
      fetch(ARCHIVE_FOUNDATION_SIGN_OUT_URL, {
        method: 'POST',
        credentials: 'include',
        cache: 'no-store',
        headers: { accept: 'application/json' }
      }).catch(function () {})
      applyLoggedOutState()
    }

    function bootstrapMemberAccess() {
      document.querySelectorAll('[data-session-sign-out]').forEach(function (button) {
        button.addEventListener('click', signOut)
      })

      var currentPath = normalizePath(window.location.pathname)
      var urlParams = new URLSearchParams(window.location.search)
      var orgAccessToken = urlParams.get('la_org_access') || ''
      var stored = readStoredOrgAccess()
      var token = orgAccessToken || (stored && stored.token) || ''

      if (token) {
        verifyOrgAccessToken(currentPath, token, stored && stored.path).then(function (valid) {
          if (valid) {
            return
          }
          clearStoredOrgAccess()
          verifyArchiveSession().then(function (loggedIn) {
            if (!loggedIn) {
              applyLoggedOutState()
            }
          })
        })
        return
      }

      verifyArchiveSession().then(function (loggedIn) {
        if (!loggedIn) {
          applyLoggedOutState()
        }
      })
    }

    bootstrapMemberAccess()
  })()
</script>
