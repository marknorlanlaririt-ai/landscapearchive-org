---
import {
  ARCHIVE_SESSION_VERIFY_URL,
  ARCHIVE_ORG_ACCESS_VERIFY_URL,
  MEMBER_ONLY_ORG_PATHS
} from '../data/memberAccess.js'
---

<script is:inline define:vars={{ ARCHIVE_SESSION_VERIFY_URL, ARCHIVE_ORG_ACCESS_VERIFY_URL, MEMBER_ONLY_ORG_PATHS }}>
  (function () {
    var ORG_ACCESS_STORAGE_KEY = 'la-foundation-org-access'

    function normalizePath(path) {
      return String(path || '').replace(/\/+$/, '') || '/'
    }

    function isMemberOnlyPath(path) {
      return MEMBER_ONLY_ORG_PATHS.indexOf(normalizePath(path)) >= 0
    }

    function setLoginBarVisible(visible) {
      document.querySelectorAll('[data-login-bar]').forEach(function (el) {
        el.hidden = !visible
      })
    }

    function applyLoggedOutState() {
      document.documentElement.dataset.archiveLoggedIn = 'false'
      document.querySelectorAll('[data-member-only]').forEach(function (el) {
        el.hidden = true
      })
      setLoginBarVisible(true)

      if (isMemberOnlyPath(window.location.pathname)) {
        window.location.replace('/governance')
      }
    }

    function applyLoggedInState() {
      document.documentElement.dataset.archiveLoggedIn = 'true'
      document.querySelectorAll('[data-member-only]').forEach(function (el) {
        el.hidden = false
      })
      setLoginBarVisible(false)
    }

    function readStoredOrgAccess() {
      try {
        var raw = sessionStorage.getItem(ORG_ACCESS_STORAGE_KEY)
        if (!raw) {
          return null
        }

        var data = JSON.parse(raw)
        if (!data || !data.token || !data.expiresAt || Number(data.expiresAt) <= Date.now()) {
          sessionStorage.removeItem(ORG_ACCESS_STORAGE_KEY)
          return null
        }

        return data
      } catch (error) {
        return null
      }
    }

    function writeStoredOrgAccess(token, expiresAt) {
      try {
        sessionStorage.setItem(ORG_ACCESS_STORAGE_KEY, JSON.stringify({
          token: token,
          expiresAt: Number(expiresAt)
        }))
      } catch (error) {
        // Private mode — session still works until tab close.
      }
    }

    function clearStoredOrgAccess() {
      try {
        sessionStorage.removeItem(ORG_ACCESS_STORAGE_KEY)
      } catch (error) {}
    }

    function stripOrgAccessTokenFromUrl() {
      var url = new URL(window.location.href)
      if (!url.searchParams.has('la_org_access')) {
        return
      }
      url.searchParams.delete('la_org_access')
      var next = url.pathname + url.search + url.hash
      window.history.replaceState({}, '', next)
    }

    function resolveVerifyPath(path) {
      var normalized = normalizePath(path)
      if (isMemberOnlyPath(normalized)) {
        return normalized
      }
      return MEMBER_ONLY_ORG_PATHS[0] || '/awards'
    }

    function verifyOrgAccessToken(path, token) {
      var verifyUrl = new URL(ARCHIVE_ORG_ACCESS_VERIFY_URL)
      verifyUrl.searchParams.set('token', token)
      verifyUrl.searchParams.set('path', resolveVerifyPath(path))

      return fetch(verifyUrl.toString(), {
        method: 'GET',
        credentials: 'include',
        cache: 'no-store',
        headers: { accept: 'application/json' }
      })
        .then(function (response) {
          return response.json().catch(function () { return {} })
        })
        .then(function (body) {
          if (body && body.valid) {
            writeStoredOrgAccess(token, body.expiresAt || Date.now() + 12 * 60 * 60 * 1000)
            applyLoggedInState()
            stripOrgAccessTokenFromUrl()
            return true
          }
          return false
        })
        .catch(function () {
          return false
        })
    }

    function verifyArchiveSession() {
      return fetch(ARCHIVE_SESSION_VERIFY_URL, {
        method: 'GET',
        credentials: 'include',
        cache: 'no-store',
        headers: { accept: 'application/json' }
      })
        .then(function (response) {
          return response.json().catch(function () { return {} })
        })
        .then(function (body) {
          if (body && body.loggedIn) {
            applyLoggedInState()
            return true
          }
          return false
        })
        .catch(function () {
          return false
        })
    }

    function bootstrapMemberAccess() {
      var currentPath = normalizePath(window.location.pathname)
      var urlParams = new URLSearchParams(window.location.search)
      var orgAccessToken = urlParams.get('la_org_access') || ''
      var stored = readStoredOrgAccess()
      var token = orgAccessToken || (stored && stored.token) || ''

      if (token) {
        verifyOrgAccessToken(currentPath, token).then(function (valid) {
          if (valid) {
            return
          }

          clearStoredOrgAccess()
          verifyArchiveSession().then(function (loggedIn) {
            if (!loggedIn) {
              applyLoggedOutState()
            }
          })
        })
        return
      }

      verifyArchiveSession().then(function (loggedIn) {
        if (!loggedIn) {
          applyLoggedOutState()
        }
      })
    }

    bootstrapMemberAccess()
  })()
</script>
