---
import {
  STANDARDS_CONSTELLATION,
  STANDARDS_CONSTELLATION_FOOTNOTE,
  STANDARDS_CONSTELLATION_INTRO,
  STANDARDS_CONSTELLATION_TITLE
} from '../data/standardsConstellation.js'

interface Props {
  id?: string
  heading?: string
}

const { id = 'standards-constellation', heading = STANDARDS_CONSTELLATION_TITLE } = Astro.props
---

<section id={id} class="constellation section-block" aria-label={heading}>
  <div class="prose">
    <h2>{heading}</h2>
    <p>{STANDARDS_CONSTELLATION_INTRO}</p>
  </div>

  <ol class="constellation__list">
    {
      STANDARDS_CONSTELLATION.map((item) => (
        <li class:list={['constellation__item', `constellation__item--${item.role}`]}>
          <div class="constellation__head">
            <span class="constellation__role">{item.role === 'spine' ? 'Spine' : 'Orbit'}</span>
            <h3 class="constellation__name">{item.shortName}</h3>
            <span class:list={['constellation__maturity', `constellation__maturity--${item.maturity}`]}>
              {item.maturityLabel}
            </span>
          </div>
          {
            item.schemaId ? (
              <p class="constellation__schema">
                <code>{item.schemaId}</code>
              </p>
            ) : null
          }
          <p class="constellation__summary">{item.summary}</p>
        </li>
      ))
    }
  </ol>

  <p class="constellation__footnote">{STANDARDS_CONSTELLATION_FOOTNOTE}</p>
</section>

<style>
  .constellation__list {
    list-style: none;
    margin: 1.6rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.85rem;
  }

  .constellation__item {
    padding: 1.15rem 1.25rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper-raised);
  }

  .constellation__item--spine {
    border-color: var(--accent);
    background: var(--paper);
  }

  .constellation__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.55rem 0.85rem;
    margin-bottom: 0.35rem;
  }

  .constellation__role {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .constellation__name {
    margin: 0;
    font-size: 1.15rem;
    flex: 1 1 auto;
  }

  .constellation__maturity {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.15rem 0.45rem;
    border-radius: 0.2rem;
    border: 1px solid var(--line);
    color: var(--ink-muted);
  }

  .constellation__maturity--published {
    color: var(--accent-strong);
    border-color: var(--accent);
  }

  .constellation__maturity--draft {
    color: var(--ink-soft);
  }

  .constellation__maturity--in-development {
    color: var(--ink-muted);
    font-weight: 500;
  }

  .constellation__schema {
    margin: 0 0 0.45rem;
    font-size: 0.8rem;
    color: var(--ink-muted);
  }

  .constellation__schema code {
    font-size: 0.78rem;
  }

  .constellation__summary {
    margin: 0;
    font-size: 0.92rem;
    color: var(--ink-soft);
    line-height: 1.45;
  }

  .constellation__footnote {
    margin: 1.1rem 0 0;
    font-size: 0.85rem;
    color: var(--ink-muted);
    line-height: 1.45;
  }
</style>
