---
import { buildArchiveOrgAccessGateUrl, isMemberOnlyOrgPath } from '../data/memberAccess.js'

interface Props {
  /** Current route path — used to tailor the handoff target when on a member page. */
  activePath?: string
}

const { activePath = '/' } = Astro.props
const handoffPath = isMemberOnlyOrgPath(activePath) ? activePath : '/awards'
const signInUrl = buildArchiveOrgAccessGateUrl(handoffPath)
---

<aside class="foundation-login-bar" data-login-bar hidden aria-label="Sign in">
  <div class="page foundation-login-bar__inner">
    <p class="foundation-login-bar__text">
      Member programme pages (Awards, Volunteers, Events) use your Landscape Archive account. The open
      specification, registry, and governance content stays public — no sign-in required.
    </p>
    <a class="foundation-login-bar__action" href={signInUrl}>Sign in</a>
  </div>
</aside>

<style>
  .foundation-login-bar {
    background: var(--paper-raised);
    border-bottom: 1px solid var(--line-soft);
  }

  .foundation-login-bar__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1.25rem;
    padding-block: 0.65rem;
  }

  .foundation-login-bar__text {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--ink-soft);
  }

  .foundation-login-bar__action {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.35rem 0.95rem;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    color: #fff;
    background: var(--accent-strong);
    border-radius: 999px;
    border: 1px solid transparent;
  }

  .foundation-login-bar__action:hover {
    background: var(--accent);
  }

  .foundation-login-bar__action:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
