---
import { ORG_SIGN_IN_PATH } from '../data/memberAccess.js'

interface Props {
  /** Current route path — used to tailor the handoff target when on a member page. */
  activePath?: string
}

const { activePath = '/' } = Astro.props
const signInPageUrl = ORG_SIGN_IN_PATH
---

<aside class="foundation-login-bar" data-login-bar hidden aria-label="Sign in">
  <div class="page foundation-login-bar__inner">
    <p class="foundation-login-bar__text">
      Member programme pages (Events) use your Landscape Archive account. The open specification,
      registry, governance, awards, and volunteer programme stay public — no sign-in required.
    </p>
    <a class="foundation-login-bar__action" href={signInPageUrl}>Sign in</a>
  </div>
</aside>

<style>
  .foundation-login-bar {
    background: var(--paper-raised);
    border-bottom: 1px solid var(--line-soft);
  }

  .foundation-login-bar__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1.25rem;
    padding-block: 0.65rem;
  }

  .foundation-login-bar__text {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--ink-soft);
  }

  .foundation-login-bar__action {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.35rem 0.85rem;
    font-family: var(--font-serif);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: var(--accent-strong);
    background: transparent;
    border-radius: 2px;
    border: 1px solid var(--accent-strong);
  }

  .foundation-login-bar__action:hover {
    background: var(--accent-strong);
    color: #f4f6f3;
  }

  .foundation-login-bar__action:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
