---
// Braced-cross Foundation mark. Uses currentColor so it adapts to context
// (ink on the light surface, inverted in the footer).
interface Props {
  size?: number
  class?: string
}
const { size = 40, class: className = '' } = Astro.props
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 120 120"
  fill="none"
  role="img"
  aria-label="The Landscape Archive Foundation mark"
>
  <rect x="54" y="16" width="12" height="88" fill="currentColor" />
  <rect x="16" y="54" width="88" height="12" fill="currentColor" />
  <line x1="60" y1="30" x2="30" y2="60" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" />
  <line x1="90" y1="60" x2="60" y2="30" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" />
  <line x1="60" y1="90" x2="90" y2="60" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" />
  <line x1="30" y1="60" x2="60" y2="90" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" />
  <rect x="55" y="6" width="10" height="10" fill="currentColor" opacity="0.55" />
  <rect x="55" y="104" width="10" height="10" fill="currentColor" opacity="0.55" />
  <rect x="6" y="55" width="10" height="10" fill="currentColor" opacity="0.55" />
  <rect x="104" y="55" width="10" height="10" fill="currentColor" opacity="0.55" />
  <rect x="55" y="55" width="10" height="10" fill="currentColor" opacity="0.55" />
</svg>
