---
/**
 * Restrained section/article share row — copy link, LinkedIn, email, Instagram cards.
 * Matches slate accent and small-caps badge styling from export profile tables.
 */
interface Props {
  /** Full share URL override. */
  url?: string
  /** Human-readable title for share text and aria labels. */
  title: string
  /** Hash anchor appended to pagePath when url is omitted. */
  anchorId?: string
  /** Page path on this site (e.g. /governance). Required unless url is set. */
  pagePath?: string
}

const { url, title, anchorId, pagePath = '/' } = Astro.props

const origin = Astro.site ?? 'https://landscapearchive.org'
const normalizedPath = pagePath.replace(/\/+$/, '') || '/'
const pathWithHash = anchorId ? `${normalizedPath}#${anchorId}` : normalizedPath
const shareUrl = url ?? new URL(pathWithHash, origin).toString()

const linkedInUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`
const emailHref = `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(`${title}\n\n${shareUrl}`)}`

const instanceId = `share-${(anchorId ?? title).replace(/[^a-z0-9]+/gi, '-').toLowerCase().slice(0, 40)}`
---

<aside
  class="section-share"
  data-share-url={shareUrl}
  data-share-title={title}
  aria-label={`Share: ${title}`}
>
  <div class="section-share__menu" data-share-menu>
    <button
      type="button"
      class="section-share__trigger"
      data-share-menu-trigger
      aria-haspopup="menu"
      aria-expanded="false"
      aria-controls={`${instanceId}-menu`}
      id={`${instanceId}-trigger`}
    >
      <span class="section-share__trigger-label">Share</span>
      <svg class="section-share__trigger-chevron" width="10" height="10" viewBox="0 0 10 10" aria-hidden="true" focusable="false">
        <path fill="currentColor" d="M2 3.5 5 6.5 8 3.5"></path>
      </svg>
    </button>
    <div
      class="section-share__panel section-share__panel--drop-down"
      id={`${instanceId}-menu`}
      role="menu"
      aria-labelledby={`${instanceId}-trigger`}
      hidden
    >
      <button type="button" class="section-share__item" role="menuitem" data-share-copy>
        <span data-share-copy-label>Copy link</span>
      </button>
      <a
        class="section-share__item section-share__item--link section-share__item--linkedin"
        role="menuitem"
        href={linkedInUrl}
        rel="noopener noreferrer"
        target="_blank"
      >
        LinkedIn
      </a>
      <a class="section-share__item section-share__item--link" role="menuitem" href={emailHref}>
        Email
      </a>
      <button type="button" class="section-share__item section-share__item--native" role="menuitem" data-share-native hidden>
        Share
      </button>
      <hr class="section-share__panel-divider" role="separator" />
      <button type="button" class="section-share__item" role="menuitem" data-share-ig="story">
        Instagram Story
      </button>
      <button type="button" class="section-share__item" role="menuitem" data-share-ig="post">
        Instagram Post
      </button>
      <button type="button" class="section-share__item" role="menuitem" data-share-caption>
        <span data-share-caption-label>Copy caption</span>
      </button>
    </div>
  </div>
  <span id={`${instanceId}-status`} class="section-share__status" role="status" aria-live="polite"></span>
</aside>

<style>
  .section-share {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem 1rem;
    margin-top: 1.6rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line-soft);
  }

  .section-share__menu {
    position: relative;
    display: inline-flex;
  }

  .section-share__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.28rem 0.55rem;
    border: 1px solid rgba(52, 61, 74, 0.35);
    border-radius: 2px;
    background: rgba(52, 61, 74, 0.04);
    color: var(--accent-strong);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 600;
    font-variant: all-small-caps;
    letter-spacing: 0.08em;
    line-height: 1;
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
  }

  .section-share__trigger:hover,
  .section-share__menu--open .section-share__trigger {
    background: rgba(52, 61, 74, 0.09);
    border-color: rgba(52, 61, 74, 0.55);
  }

  .section-share__trigger-chevron {
    flex-shrink: 0;
    transition: transform 140ms ease;
  }

  .section-share__menu--open .section-share__trigger-chevron {
    transform: rotate(180deg);
  }

  .section-share__panel[hidden] {
    display: none !important;
  }

  .section-share__panel {
    position: absolute;
    left: 0;
    z-index: 30;
    display: flex;
    flex-direction: column;
    min-width: 11.5rem;
    padding: 0.35rem 0;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: var(--paper-raised, #ffffff);
    box-shadow: 0 6px 20px rgba(28, 31, 34, 0.12);
  }

  .section-share__panel--floating {
    position: fixed;
    top: auto;
    left: auto;
    bottom: auto;
    z-index: 1100;
    margin: 0;
  }

  .section-share__backdrop {
    position: fixed;
    inset: 0;
    z-index: 1099;
    margin: 0;
    padding: 0;
    border: 0;
    background: rgba(28, 31, 34, 0.16);
    cursor: default;
    touch-action: manipulation;
  }

  .section-share__backdrop[hidden] {
    display: none !important;
  }

  .section-share__panel--drop-down {
    top: calc(100% + 0.35rem);
    bottom: auto;
  }

  .section-share__panel--drop-up {
    bottom: calc(100% + 0.35rem);
    top: auto;
  }

  .section-share__panel-divider {
    margin: 0.35rem 0;
    border: 0;
    border-top: 1px solid var(--line-soft);
  }

  .section-share__item {
    display: flex;
    align-items: center;
    width: 100%;
    padding: 0.45rem 0.75rem;
    border: 0;
    background: transparent;
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: 1.3;
    text-align: left;
    text-decoration: none;
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    transition: background 120ms ease, color 120ms ease;
  }

  @media (max-width: 720px) {
    .section-share__trigger {
      min-height: 44px;
      padding: 0.5rem 0.75rem;
    }

    .section-share__item {
      min-height: 44px;
      padding: 0.65rem 0.85rem;
    }
  }

  .section-share__item:hover,
  .section-share__item:focus-visible {
    background: rgba(52, 61, 74, 0.06);
    color: var(--accent-strong);
    outline: none;
  }

  .section-share__item--done {
    color: var(--accent-strong);
    font-weight: 600;
  }

  .section-share__item:disabled {
    opacity: 0.55;
    cursor: wait;
  }

  .section-share__item--native:not([hidden]) ~ .section-share__item--linkedin {
    display: none;
  }

  .section-share__panel:has(.section-share__item--native:not([hidden])) .section-share__item--linkedin {
    display: none;
  }

  @media (min-width: 721px) {
    .section-share__item--native {
      display: none !important;
    }
  }

  .section-share__status {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
