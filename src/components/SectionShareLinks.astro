---
/**
 * Restrained section/article share row — copy link, optional LinkedIn and email.
 * Matches slate accent and small-caps badge styling from export profile tables.
 */
interface Props {
  /** Full share URL override. */
  url?: string
  /** Human-readable title for share text and aria labels. */
  title: string
  /** Hash anchor appended to pagePath when url is omitted. */
  anchorId?: string
  /** Page path on this site (e.g. /governance). Required unless url is set. */
  pagePath?: string
}

const { url, title, anchorId, pagePath = '/' } = Astro.props

const origin = Astro.site ?? 'https://landscapearchive.org'
const normalizedPath = pagePath.replace(/\/+$/, '') || '/'
const pathWithHash = anchorId ? `${normalizedPath}#${anchorId}` : normalizedPath
const shareUrl = url ?? new URL(pathWithHash, origin).toString()

const linkedInUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`
const emailHref = `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(`${title}\n\n${shareUrl}`)}`

const instanceId = `share-${(anchorId ?? title).replace(/[^a-z0-9]+/gi, '-').toLowerCase().slice(0, 40)}`
---

<aside
  class="section-share"
  data-share-url={shareUrl}
  data-share-title={title}
  aria-label={`Share: ${title}`}
>
  <span class="section-share__label">Share</span>
  <div class="section-share__actions">
    <button
      type="button"
      class="section-share__btn section-share__btn--copy"
      data-share-copy
      aria-describedby={`${instanceId}-status`}
    >
      <span class="section-share__btn-label" data-share-copy-label>Copy link</span>
    </button>
    <button
      type="button"
      class="section-share__btn section-share__btn--native"
      data-share-native
      hidden
    >
      Share
    </button>
    <a
      class="section-share__icon"
      href={linkedInUrl}
      rel="noopener noreferrer"
      target="_blank"
      aria-label="Share on LinkedIn"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          fill="currentColor"
          d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 114.127 0 2.062 2.062 0 01-2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
        ></path>
      </svg>
    </a>
    <a class="section-share__icon" href={emailHref} aria-label="Share by email">
      <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          fill="currentColor"
          d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
        ></path>
      </svg>
    </a>
  </div>
  <span id={`${instanceId}-status`} class="section-share__status" role="status" aria-live="polite"></span>
</aside>

<script>
  function initSectionShare(root: HTMLElement) {
    const shareUrl = root.dataset.shareUrl
    const shareTitle = root.dataset.shareTitle
    if (!shareUrl) return

    const copyBtn = root.querySelector<HTMLButtonElement>('[data-share-copy]')
    const copyLabel = root.querySelector<HTMLElement>('[data-share-copy-label]')
    const nativeBtn = root.querySelector<HTMLButtonElement>('[data-share-native]')
    const status = root.querySelector<HTMLElement>('.section-share__status')

    if (nativeBtn && typeof navigator.share === 'function') {
      nativeBtn.hidden = false
      nativeBtn.addEventListener('click', async () => {
        try {
          await navigator.share({ title: shareTitle ?? document.title, url: shareUrl })
        } catch (err) {
          if ((err as Error).name !== 'AbortError') copyLink()
        }
      })
    }

    async function copyLink() {
      try {
        await navigator.clipboard.writeText(shareUrl)
        showCopied()
      } catch {
        const input = document.createElement('input')
        input.value = shareUrl
        document.body.appendChild(input)
        input.select()
        document.execCommand('copy')
        input.remove()
        showCopied()
      }
    }

    function showCopied() {
      if (copyLabel) copyLabel.textContent = 'Copied'
      if (copyBtn) copyBtn.classList.add('section-share__btn--done')
      if (status) status.textContent = 'Link copied to clipboard'
      window.setTimeout(() => {
        if (copyLabel) copyLabel.textContent = 'Copy link'
        if (copyBtn) copyBtn.classList.remove('section-share__btn--done')
        if (status) status.textContent = ''
      }, 2200)
    }

    copyBtn?.addEventListener('click', copyLink)
  }

  document.querySelectorAll<HTMLElement>('.section-share').forEach(initSectionShare)
</script>

<style>
  .section-share {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem 1rem;
    margin-top: 1.6rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line-soft);
  }

  .section-share__label {
    font-size: 0.68rem;
    font-weight: 600;
    font-variant: all-small-caps;
    letter-spacing: 0.08em;
    line-height: 1;
    color: var(--ink-muted);
  }

  .section-share__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem 0.65rem;
  }

  .section-share__btn {
    display: inline-flex;
    align-items: center;
    padding: 0.28rem 0.55rem;
    border: 1px solid rgba(52, 61, 74, 0.35);
    border-radius: 2px;
    background: rgba(52, 61, 74, 0.04);
    color: var(--accent-strong);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 600;
    font-variant: all-small-caps;
    letter-spacing: 0.08em;
    line-height: 1;
    cursor: pointer;
    transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
  }

  .section-share__btn:hover {
    background: rgba(52, 61, 74, 0.09);
    border-color: rgba(52, 61, 74, 0.55);
  }

  .section-share__btn--done {
    border-color: var(--accent-strong);
    color: var(--accent-strong);
    background: rgba(52, 61, 74, 0.08);
  }

  .section-share__btn--native:not([hidden]) ~ .section-share__icon[aria-label='Share on LinkedIn'] {
    display: none;
  }

  @media (min-width: 721px) {
    .section-share__btn--native {
      display: none !important;
    }
  }

  .section-share__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.65rem;
    height: 1.65rem;
    border: 1px solid var(--line);
    border-radius: 2px;
    color: var(--ink-muted);
    background: transparent;
    text-decoration: none;
    transition: color 140ms ease, border-color 140ms ease, background 140ms ease;
  }

  .section-share__icon:hover {
    color: var(--accent-strong);
    border-color: rgba(52, 61, 74, 0.4);
    background: rgba(52, 61, 74, 0.04);
  }

  .section-share__status {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
