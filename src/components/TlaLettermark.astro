---
interface Props {
  size?: number
  class?: string
  title?: string
}

const {
  size = 34,
  class: className = '',
  title = 'The Landscape Archive'
} = Astro.props
---

<svg
  class:list={['tla-lettermark', className]}
  width={size}
  height={size}
  viewBox="0 0 48 48"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label={title}
>
  <rect x="6" y="8" width="36" height="2.25" rx="0.5" fill="#8fa3b0" />
  <text
    x="24"
    y="29.5"
    text-anchor="middle"
    font-family="Inter, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif"
    font-size="13.5"
    font-weight="500"
    letter-spacing="0.18em"
    fill="currentColor">TLA</text>
  <rect x="6" y="35" width="22" height="2.25" rx="0.5" fill="#8fa3b0" />
</svg>

<style>
  .tla-lettermark {
    display: block;
    flex-shrink: 0;
    color: var(--ink, #4a443f);
  }
</style>
