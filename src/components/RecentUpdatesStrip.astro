---
import { FOUNDATION_RECENT_PUBLIC_UPDATES } from '../data/recentPublicUpdates.js'

const { updates = FOUNDATION_RECENT_PUBLIC_UPDATES } = Astro.props
---

<section class="updates-strip" aria-labelledby="recent-updates-heading">
  <div class="page updates-strip__inner">
    <div class="updates-strip__header">
      <p class="eyebrow">What's new</p>
      <h2 id="recent-updates-heading" class="updates-strip__title">Recent public updates</h2>
      <p class="updates-strip__lead">
        Interim milestones on the open specification and draft governance — for consultation, not as claims of
        incorporated charity status or active programmes.
      </p>
    </div>
    <ul class="updates-strip__list">
      {
        updates.map((item) => (
          <li class="updates-strip__item">
            <time class="updates-strip__date" datetime={item.date}>{item.date}</time>
            <h3 class="updates-strip__item-title">
              <a
                class="updates-strip__link"
                href={item.href}
                {...(item.external ? { rel: 'noopener', target: '_blank' } : {})}
              >
                {item.title}
              </a>
            </h3>
            <p class="updates-strip__summary">{item.summary}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .updates-strip {
    border-bottom: 1px solid var(--line-soft);
    background: var(--accent-tint);
  }

  .updates-strip__inner {
    padding-block: clamp(1.6rem, 4vw, 2.2rem);
  }

  .updates-strip__header {
    max-width: var(--measure);
    margin-bottom: 1.25rem;
  }

  .updates-strip__title {
    margin: 0.15rem 0 0.45rem;
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 3vw, 1.65rem);
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
  }

  .updates-strip__lead {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  .updates-strip__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.85rem;
  }

  @media (min-width: 720px) {
    .updates-strip__list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }
  }

  .updates-strip__item {
    padding: 0.95rem 1rem;
    background: var(--paper-raised);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-sm);
  }

  .updates-strip__date {
    display: block;
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 0.35rem;
  }

  .updates-strip__item-title {
    margin: 0 0 0.35rem;
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.3;
  }

  .updates-strip__link {
    color: var(--ink);
    text-decoration: none;
  }

  .updates-strip__link:hover {
    color: var(--accent-strong);
    text-decoration: underline;
    text-underline-offset: 0.16em;
  }

  .updates-strip__summary {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--ink-soft);
  }
</style>
