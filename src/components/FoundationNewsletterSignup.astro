---
import { ARCHIVE_ORIGIN } from '../data/site.js'

const apiUrl = `${ARCHIVE_ORIGIN}/api/foundation/newsletter`
---

<form
  id="foundation-updates"
  class="foundation-newsletter"
  data-foundation-newsletter
  data-api-url={apiUrl}
>
  <label class="foundation-newsletter__label" for="foundation-newsletter-email">
    Foundation updates
  </label>
  <p class="foundation-newsletter__hint">
    Occasional mail about the open TLA specification, registry releases, and governance milestones.
  </p>
  <div class="foundation-newsletter__row">
    <input
      id="foundation-newsletter-email"
      class="foundation-newsletter__input"
      type="email"
      name="email"
      autocomplete="email"
      inputmode="email"
      placeholder="you@example.org"
      required
    />
    <button class="btn btn--primary foundation-newsletter__submit" type="submit">Subscribe</button>
  </div>
  <input class="foundation-newsletter__honeypot" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" />
  <p class="foundation-newsletter__status" data-status hidden></p>
</form>

<script>
  const forms = document.querySelectorAll('[data-foundation-newsletter]')

  forms.forEach((form) => {
    if (!(form instanceof HTMLFormElement)) return

    const apiUrl = form.dataset.apiUrl || ''
    const statusEl = form.querySelector('[data-status]')
    const submitButton = form.querySelector('button[type="submit"]')

    form.addEventListener('submit', async (event) => {
      event.preventDefault()

      if (!apiUrl) return

      const formData = new FormData(form)
      const email = String(formData.get('email') || '').trim()
      const website = String(formData.get('website') || '').trim()

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true
      }

      if (statusEl instanceof HTMLElement) {
        statusEl.hidden = false
        statusEl.textContent = 'Submitting…'
        statusEl.dataset.state = 'pending'
      }

      try {
        const response = await fetch(apiUrl, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({
            email,
            website,
            pagePath: window.location.pathname
          })
        })

        const payload = await response.json().catch(() => ({}))
        const message = payload?.message
          || (response.ok ? 'Subscription received.' : 'Unable to subscribe right now.')

        if (statusEl instanceof HTMLElement) {
          statusEl.textContent = message
          statusEl.dataset.state = response.ok ? 'success' : 'error'
        }

        if (response.ok) {
          form.reset()
        }
      } catch {
        if (statusEl instanceof HTMLElement) {
          statusEl.textContent = 'Network error — please try again shortly.'
          statusEl.dataset.state = 'error'
        }
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false
        }
      }
    })
  })
</script>

<style>
  .foundation-newsletter {
    margin-top: 1.25rem;
    max-width: 24rem;
  }

  .foundation-newsletter__label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #9fb0a3;
    margin-bottom: 0.35rem;
  }

  .foundation-newsletter__hint {
    margin: 0 0 0.75rem;
    font-size: 0.82rem;
    line-height: 1.5;
    color: #c4cfc6;
  }

  .foundation-newsletter__row {
    display: flex;
    align-items: stretch;
    flex-wrap: nowrap;
    gap: 0;
    max-width: 100%;
  }

  .foundation-newsletter__input,
  .foundation-newsletter__submit {
    min-height: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    font-family: var(--font-sans);
    font-size: 0.88rem;
    line-height: 1.25;
  }

  .foundation-newsletter__input {
    flex: 1 1 auto;
    min-width: 0;
    padding: 0.55rem 0.75rem;
    border-right: 0;
    border-radius: var(--radius-sm) 0 0 var(--radius-sm);
    background: rgba(255, 255, 255, 0.06);
    color: #eef2ee;
  }

  .foundation-newsletter__input::placeholder {
    color: rgba(238, 242, 238, 0.45);
  }

  .foundation-newsletter__input:focus {
    outline: none;
    border-color: rgba(255, 255, 255, 0.32);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.12);
  }

  .foundation-newsletter__input:focus + .foundation-newsletter__submit {
    border-color: rgba(255, 255, 255, 0.32);
  }

  .foundation-newsletter__submit {
    flex: 0 0 auto;
    margin: 0;
    padding: 0.55rem 0.9rem;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.04);
    color: #eef2ee;
    font-weight: 600;
    letter-spacing: 0.02em;
    align-items: center;
    cursor: pointer;
    white-space: nowrap;
  }

  .foundation-newsletter__submit:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.32);
    color: #ffffff;
  }

  .foundation-newsletter__submit:disabled {
    opacity: 0.6;
    cursor: wait;
  }

  .foundation-newsletter__honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .foundation-newsletter__status {
    margin: 0.65rem 0 0;
    font-size: 0.8rem;
    line-height: 1.45;
    color: #c4cfc6;
  }

  .foundation-newsletter__status[data-state='success'] {
    color: #d8eadf;
  }

  .foundation-newsletter__status[data-state='error'] {
    color: #f0c9c9;
  }
</style>
