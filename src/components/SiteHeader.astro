---
import { SITE_NAV_LINKS, FOUNDATION_DISPLAY_NAME } from '../data/site.js'
import TlaLettermark from './TlaLettermark.astro'
import FoundationSessionChrome from './FoundationSessionChrome.astro'

interface Props {
  activePath?: string
}
const { activePath = '/' } = Astro.props

const normalize = (p: string) => (p !== '/' ? p.replace(/\/+$/, '') : p)
const current = normalize(activePath)
---

<header class="site-header">
  <div class="page site-header__inner">
    <a class="site-header__brand" href="/" aria-label={`${FOUNDATION_DISPLAY_NAME} home`}>
      <TlaLettermark class="site-header__logo" size={56} />
      <span class="site-header__wordmark">
        <span class="site-header__word">The Landscape Archive</span>
        <span class="site-header__word site-header__word--strong">Foundation</span>
      </span>
    </a>

    <nav class="site-header__nav" aria-label="Foundation navigation">
      {
        SITE_NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={['site-header__link', { 'is-active': normalize(link.href) === current }]}
            aria-current={normalize(link.href) === current ? 'page' : undefined}
            data-member-only={link.requiresLogin ? '' : undefined}
            hidden={link.requiresLogin ? true : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <FoundationSessionChrome activePath={activePath} />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: saturate(1.1) blur(10px);
    border-bottom: 1px solid var(--line-soft);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: var(--foundation-header-min-height);
    padding-block: 0.35rem;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--foundation-header-brand-gap);
    color: var(--ink);
    text-decoration: none;
    flex-shrink: 0;
    max-width: min(100%, 22rem);
  }

  .site-header__logo {
    width: var(--foundation-header-mark-size);
    height: var(--foundation-header-mark-size);
  }

  .site-header__wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }

  .site-header__word {
    font-size: var(--foundation-header-word-size);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .site-header__word--strong {
    font-weight: 600;
    color: var(--ink);
    letter-spacing: 0.2em;
  }

  .site-header__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.15rem;
    justify-content: flex-end;
  }

  .site-header__link {
    font-size: 0.86rem;
    color: var(--ink-soft);
    text-decoration: none;
    padding: 0.3rem 0;
    border-bottom: 2px solid transparent;
  }

  .site-header__link:hover {
    color: var(--accent-strong);
  }

  .site-header__link.is-active {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 860px) {
    .site-header__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.6rem;
      padding-block: 0.7rem;
    }

    .site-header__nav {
      justify-content: flex-start;
    }
  }
</style>
