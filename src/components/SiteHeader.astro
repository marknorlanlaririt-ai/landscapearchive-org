---
import { SITE_NAV_LINKS, FOUNDATION_DISPLAY_NAME } from '../data/site.js'
import TlaLettermark from './TlaLettermark.astro'
import FoundationSessionChrome from './FoundationSessionChrome.astro'

interface Props {
  activePath?: string
}
const { activePath = '/' } = Astro.props

const normalize = (p: string) => (p !== '/' ? p.replace(/\/+$/, '') : p)
const current = normalize(activePath)
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-header__brand" href="/" aria-label={`${FOUNDATION_DISPLAY_NAME} home`}>
      <TlaLettermark class="site-header__logo" size={56} />
      <span class="site-header__wordmark">
        <span class="site-header__word">The Landscape Archive</span>
        <span class="site-header__word site-header__word--strong">Foundation</span>
      </span>
    </a>

    <div class="site-header__end">
      <nav class="site-header__nav" aria-label="Foundation navigation">
        {
          SITE_NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class:list={['site-header__link', { 'is-active': normalize(link.href) === current }]}
              aria-current={normalize(link.href) === current ? 'page' : undefined}
              data-member-only={link.requiresLogin ? '' : undefined}
              hidden={link.requiresLogin ? true : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <FoundationSessionChrome activePath={activePath} />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: var(--accent-strong);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem 1.25rem;
    width: 100%;
    max-width: none;
    margin-inline: 0;
    padding-inline: clamp(1.1rem, 4vw, 2.5rem);
    min-height: var(--foundation-header-min-height);
    padding-block: 0.35rem;
    flex-wrap: nowrap;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--foundation-header-brand-gap);
    color: #eef2ee;
    text-decoration: none;
    flex-shrink: 0;
    min-width: 0;
  }

  .site-header__end {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem 1rem;
    flex: 1 1 auto;
    min-width: 0;
  }

  .site-header__logo {
    width: var(--foundation-header-mark-size);
    height: var(--foundation-header-mark-size);
    --tla-lettermark-text: #eef2ee;
  }

  .site-header__wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }

  .site-header__word {
    font-size: var(--foundation-header-word-size);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #c4cfc6;
  }

  .site-header__word--strong {
    font-weight: 600;
    color: #ffffff;
    letter-spacing: 0.2em;
  }

  .site-header__nav {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.25rem clamp(0.45rem, 1vw, 0.85rem);
    justify-content: flex-end;
    flex: 1 1 auto;
    min-width: 0;
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .site-header__nav::-webkit-scrollbar {
    display: none;
  }

  .site-header__link {
    font-size: 0.82rem;
    color: #dfe6e0;
    text-decoration: none;
    padding: 0.3rem 0;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .site-header__link:hover {
    color: #ffffff;
  }

  .site-header__link.is-active {
    color: #ffffff;
    border-bottom-color: #9fb0a3;
  }

  @media (max-width: 720px) {
    .site-header__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.6rem;
      padding-block: 0.7rem;
    }

    .site-header__end {
      width: 100%;
      flex-direction: column;
      align-items: flex-start;
    }

    .site-header__nav {
      justify-content: flex-start;
      width: 100%;
      flex-wrap: wrap;
      overflow-x: visible;
    }
  }
</style>
