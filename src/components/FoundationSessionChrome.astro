---
import {
  buildArchiveOrgAccessGateUrl,
  ORG_SIGN_IN_PATH,
  resolveOrgAccessHandoffPath
} from '../data/memberAccess.js'

interface Props {
  activePath?: string
}

const { activePath = '/' } = Astro.props
const handoffPath = resolveOrgAccessHandoffPath(activePath)
const signInUrl = buildArchiveOrgAccessGateUrl(handoffPath)
const signInPageUrl = ORG_SIGN_IN_PATH
---

<div class="foundation-session-chrome" data-session-chrome hidden aria-live="polite">
  <span class="foundation-session-chrome__label" data-session-email></span>
  <button type="button" class="foundation-session-chrome__action" data-session-sign-out>
    Log out
  </button>
</div>

<a
  class="foundation-session-chrome foundation-session-chrome--guest"
  data-session-guest
  href={signInPageUrl}
  data-session-sign-in-archive={signInUrl}
>
  Sign in
</a>

<style>
  .foundation-session-chrome {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    flex-shrink: 0;
    font-size: 0.82rem;
    color: #c5cad1;
    text-decoration: none;
  }

  .foundation-session-chrome[hidden] {
    display: none;
  }

  .foundation-session-chrome__label {
    max-width: 16rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .foundation-session-chrome__action,
  .foundation-session-chrome--guest {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.35rem 0.75rem;
    font-family: var(--font-serif);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: #eef0f4;
    background: transparent;
    border-radius: 2px;
    border: 1px solid rgba(238, 240, 244, 0.45);
    cursor: pointer;
  }

  .foundation-session-chrome__action:hover,
  .foundation-session-chrome--guest:hover {
    border-color: #ffffff;
    color: #ffffff;
    background: rgba(255, 255, 255, 0.12);
  }

  .foundation-session-chrome__action:focus-visible,
  .foundation-session-chrome--guest:focus-visible {
    outline: 2px solid #8fa0b0;
    outline-offset: 2px;
  }

  @media (max-width: 720px) {
    .foundation-session-chrome--guest {
      min-height: 1.75rem;
      padding: 0.25rem 0.55rem;
      font-size: 0.74rem;
    }

    .foundation-session-chrome:not(.foundation-session-chrome--guest) {
      gap: 0.35rem;
    }

    .foundation-session-chrome__label {
      max-width: 7.5rem;
      font-size: 0.72rem;
    }

    .foundation-session-chrome__action {
      min-height: 1.75rem;
      padding: 0.25rem 0.45rem;
      font-size: 0.74rem;
    }
  }
</style>
