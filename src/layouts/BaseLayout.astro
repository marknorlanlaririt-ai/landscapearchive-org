---
import '../styles/global.css'
import SiteHeader from '../components/SiteHeader.astro'
import SiteFooter from '../components/SiteFooter.astro'
import DraftBanner from '../components/DraftBanner.astro'
import ArchiveSessionBootstrap from '../components/ArchiveSessionBootstrap.astro'
import CookieNotice from '../components/CookieNotice.astro'
import { SITE_ORIGIN, SITE_DESCRIPTION, FOUNDATION_DISPLAY_NAME, SCHEMA_PORTAL_URL } from '../data/site.js'
import { OPEN_STANDARD_GITHUB_URL, isOpenStandardGithubPubliclyAvailable } from '../data/foundationWing.js'

interface Props {
  title: string
  description?: string
  /** Route path for canonical URL + active nav (e.g. "/governance"). */
  path?: string
  ogImage?: string
  ogImageAlt?: string
  showDraftBanner?: boolean
  /** When true, emit noindex and skip WebSite discovery hints. */
  noindex?: boolean
}

const {
  title,
  description = SITE_DESCRIPTION,
  path = Astro.url.pathname,
  ogImage = '/og-foundation.png',
  ogImageAlt = 'The Landscape Archive Foundation — open TLA-185 landscape metadata standard',
  showDraftBanner = true,
  noindex = false
} = Astro.props

const canonical = new URL(path === '/' ? '/' : path.replace(/\/+$/, ''), SITE_ORIGIN).toString()
const brandHost = 'The Landscape Archive | Foundation'
const isHomeTitle =
  !title
  || title === FOUNDATION_DISPLAY_NAME
  || title === brandHost
  || title === 'The Landscape Archive'
const fullTitle = isHomeTitle ? brandHost : `${title} · ${brandHost}`
const ogImageUrl = new URL(ogImage, SITE_ORIGIN).toString()
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow'

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: FOUNDATION_DISPLAY_NAME,
  alternateName: 'TLA Foundation',
  url: SITE_ORIGIN,
  description: SITE_DESCRIPTION,
  logo: new URL('/tla-foundation-mark.svg', SITE_ORIGIN).toString(),
  sameAs: [
    ...(isOpenStandardGithubPubliclyAvailable() ? [OPEN_STANDARD_GITHUB_URL] : []),
    SCHEMA_PORTAL_URL
  ]
}

const websiteJsonLd = noindex
  ? null
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: FOUNDATION_DISPLAY_NAME,
      url: SITE_ORIGIN,
      description: SITE_DESCRIPTION,
      publisher: { '@type': 'Organization', name: FOUNDATION_DISPLAY_NAME },
      inLanguage: 'en'
    }

const structuredData = websiteJsonLd ? [orgJsonLd, websiteJsonLd] : [orgJsonLd]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/tla-foundation-mark.svg" />
    <link rel="apple-touch-icon" href="/tla-foundation-mark.svg" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#343d4a" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={FOUNDATION_DISPLAY_NAME} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="en" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/json" title="TLA-185 schema portal" href={SCHEMA_PORTAL_URL} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} is:inline />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <SiteHeader activePath={path} />
    {showDraftBanner && <DraftBanner />}
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
    <ArchiveSessionBootstrap />
    <CookieNotice />
    <script src="/scripts/section-share.js?v=20260709c" defer></script>
    <script src="/scripts/foundation-chrome-mobile.js" defer></script>

    <style>
      .skip-link {
        position: absolute;
        left: -999px;
        top: 0;
        z-index: 40;
        background: var(--accent-strong);
        color: #fff;
        padding: 0.6rem 1rem;
        border-radius: 0 0 var(--radius-sm) 0;
      }
      .skip-link:focus {
        left: 0;
      }
    </style>
  </body>
</html>
